# ============================================
# Lets Train — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local

# --------------------------------------------
# Supabase (obrigatório para rodar o app)
# Criar projeto em: https://supabase.com
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------------------------
# Anthropic / Claude API (obrigatório para geração de treinos)
# Criar chave em: https://console.anthropic.com
# --------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# --------------------------------------------
# Stripe (obrigatório para pagamentos)
# Criar conta em: https://stripe.com
# Chaves em: Dashboard → Developers → API Keys
# --------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: Dashboard → Developers → Webhooks → Add endpoint
# Event: payment_intent.succeeded | URL: https://seu-dominio/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# --------------------------------------------
# Web Push / VAPID (obrigatório para push notifications)
# Gerar em: npx web-push generate-vapid-keys
# --------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BExamplePublicKeyHere...
VAPID_PRIVATE_KEY=ExamplePrivateKeyHere...

# --------------------------------------------
# Cron Secret (protege o endpoint /api/push/send)
# Use qualquer string aleatória segura
# --------------------------------------------
CRON_SECRET=seu-secret-aleatorio-aqui

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
